PORT=3000
JWT_SECRET=your_super_secret_jwt_key_change_in_production
NODE_ENV=development
# Frontend URL for CORS restriction (change to your actual frontend URL in production)
FRONTEND_URL=http://localhost:5173
# Set false if you want local backups only and no git push
BACKUP_GIT_PUSH=true
# Optional: explicit path to the git clone that should receive backup commits
# BACKUP_GIT_REPO_PATH=C:\path\to\tracking-clone
